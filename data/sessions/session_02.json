  "code": "def is_valid(s: str) -> bool:\n    stack = []\n    mapping = {')': '(', '}': '{', ']': '['}\n    for char in s:\n        if char in mapping:\n            if not stack or stack[-1] != mapping[char]:\n                return False\n            stack.pop()\n        else:\n            stack.append(char)\n    return len(stack) == 0\n\nassert is_valid('()')\nassert is_valid('()[]{}')\nassert not is_valid('(]')\nassert not is_valid('([)]')\nassert is_valid('{[]}')\nprint('all tests pass')",
