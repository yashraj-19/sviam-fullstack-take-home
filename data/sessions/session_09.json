  "code": "def is_valid(s):\n    stack = []\n    for c in s:\n        if c == '(' or c == '{' or c == '[':\n            stack.append(c)\n        elif c == ')':\n            if len(stack) == 0 or stack[-1] != '(':\n                return False\n            stack.pop()\n        elif c == '}':\n            if len(stack) == 0 or stack[-1] != '{':\n                return False\n            stack.pop()\n        elif c == ']':\n            if len(stack) == 0 or stack[-1] != '[':\n                return False\n            stack.pop()\n    return len(stack) == 0\n\nprint(is_valid('()'))      # True\nprint(is_valid('()[]{}'))  # True\nprint(is_valid('(]'))      # False\nprint(is_valid('([)]'))    # False\nprint(is_valid('{[]}'))    # True",
