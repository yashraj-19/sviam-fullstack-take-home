  "code": "def merge(intervals):\n    if len(intervals) <= 1:\n        return intervals\n    \n    intervals.sort()\n    result = [intervals[0]]\n    \n    for i in range(1, len(intervals)):\n        if intervals[i][0] <= result[-1][1]:\n            result[-1][1] = max(result[-1][1], intervals[i][1])\n        else:\n            result.append(intervals[i])\n    \n    return result\n\nprint(merge([[1,3],[2,6],[8,10],[15,18]]))\nprint(merge([[1,4],[4,5]]))\nprint(merge([[1,4],[0,0]]))\nprint(merge([]))",
